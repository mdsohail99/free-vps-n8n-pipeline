# Copy this file to ".env" and fill in your real values. Never commit ".env" to git.

# The domain pointing at your VPS, e.g. n8n.yourdomain.com.
# Requires a DNS A record pointing this domain at your VPS public IP.
N8N_HOST=n8n.yourdomain.com

# Public URL n8n should use when generating webhook URLs.
# Domain/HTTPS mode: https://n8n.yourdomain.com/
# No-domain/IP-only mode: http://YOUR_SERVER_IP:5678/
WEBHOOK_URL=https://n8n.yourdomain.com/

# Domain/HTTPS mode: https
# No-domain/IP-only mode: http
N8N_PROTOCOL=https

# Keep true behind Caddy HTTPS. Set false only for no-domain HTTP mode.
N8N_SECURE_COOKIE=true

# Your timezone, used by n8n scheduling and $now date formatting.
# Find yours at https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
GENERIC_TIMEZONE=UTC

# From your Notion database URL after the database has been created.
NOTION_DATABASE_ID=your_notion_database_id_here

# Notion internal integration token. Do not include a "Bearer " prefix here.
NOTION_INTEGRATION_TOKEN=ntn_your_token_here

# Parent page ID where setup_notion_db.py will create the AI Daily Reports database.
# The parent page must be shared with your Notion integration before running the script.
NOTION_PARENT_PAGE_ID=your_page_id_here

# VPS public IP address, used in SSH examples and no-domain WEBHOOK_URL.
VPS_IP=your.vps.ip

# Slack webhook URL for morning briefing notifications.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Allows n8n Code nodes to read environment variables used by this workflow.
# Security trade-off: anyone who can edit/run Code nodes can read env vars.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
